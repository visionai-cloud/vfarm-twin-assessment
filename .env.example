# --- Storage ---
# Default is a local SQLite file so the pipeline runs with zero setup.
# For the "real" stack, point this at Postgres:
#   DATABASE_URL=postgresql+psycopg://vfarm:vfarm@localhost:5432/vfarm
DATABASE_URL=sqlite:///./vfarm.db

# --- Source A: webhook auth ---
# Shared secret required in the `X-VFarm-Token` header on POST /ingest/webhook.
# Webhooks are public HTTP endpoints, so they must be authenticated.
WEBHOOK_TOKEN=dev-secret-change-me

# --- Source B: builder update sheet ---
# A Google Sheet published as CSV (File -> Share -> Publish to web -> CSV),
# or any URL / local path returning CSV with columns:
#   timestamp,type,location,notes,source_event_id
SHEET_CSV_URL=./sample_data/builder_updates.csv

# How often the poller pulls Source B (seconds). Used by the standalone poller.
SHEET_POLL_SECONDS=300

# --- AI narration (optional) ---
# Leave OPENAI_API_KEY empty to use the deterministic template fallback (zero
# cost, works offline). Set it to enable LLM narration of the 24h summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
